.DS_Store

# Personal insurance documents (certificate + purchase screenshot contain names,
# DOBs, policy number, payment details) — keep out of this public repo.
insurance/

# Personal flight ticket (contains name, booking reference) — keep out of this public repo.
air-tickets/

# Filled ESTA application templates (contain full names, DOBs, passport numbers,
# home address, emergency contacts) — keep out of this public repo.
ESTA/

# Confidential trip data (hotel addresses, confirmation numbers, booking
# references, contact details) — kept on disk only, never committed.
private/
